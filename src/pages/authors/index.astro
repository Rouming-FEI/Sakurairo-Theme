---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, getAuthorMap, slugifyTerm } from "../../lib/posts";

const posts = await getPublishedPosts();
const authors = [...getAuthorMap(posts).entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="作者 | Sakurairo Astro" description="作者聚合页">
  <section class="article-shell">
    <h1>作者</h1>
    <ul class="tag-cloud">
      {authors.map(([author, list]) => (
        <li>
          <a href={`/authors/${slugifyTerm(author)}`}>{author} ({list.length})</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
