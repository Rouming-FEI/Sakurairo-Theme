---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, getAuthorMap, slugifyTerm } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const authors = [...getAuthorMap(posts).keys()];

  return authors.map((author) => ({
    params: { author: slugifyTerm(author) },
    props: { author }
  }));
}

const { author } = Astro.props;
const posts = await getPublishedPosts();
const authorMap = getAuthorMap(posts);
const list = authorMap.get(author) ?? [];
---

<BaseLayout title={`${author} | 作者`} description={`${author} 的文章列表`}>
  <section class="hero">
    <h1>作者: {author}</h1>
    <p>共 {list.length} 篇文章</p>
  </section>
  <section class="post-list" aria-label="作者文章列表">
    {list.map((post) => (
      <PostCard
        href={`/posts/${post.slug}`}
        title={post.data.title}
        description={post.data.description}
        publishDate={post.data.publishDate}
        tags={post.data.tags}
      />
    ))}
  </section>
</BaseLayout>
