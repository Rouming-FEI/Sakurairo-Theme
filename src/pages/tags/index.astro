---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, getTagMap, slugifyTag } from "../../lib/posts";

const posts = await getPublishedPosts();
const tags = [...getTagMap(posts).entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="标签 | Sakurairo Astro" description="标签聚合页">
  <section class="article-shell">
    <h1>标签</h1>
    <ul class="tag-cloud">
      {tags.map(([tag, list]) => (
        <li>
          <a href={`/tags/${slugifyTag(tag)}`}>{tag} ({list.length})</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
