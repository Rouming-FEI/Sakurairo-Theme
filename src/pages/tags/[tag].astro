---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, getTagMap, slugifyTag } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = [...getTagMap(posts).keys()];

  return tags.map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const posts = await getPublishedPosts();
const tagMap = getTagMap(posts);
const list = tagMap.get(tag) ?? [];
---

<BaseLayout title={`${tag} | 标签`} description={`${tag} 标签下的文章列表`}>
  <section class="hero">
    <h1>标签: {tag}</h1>
    <p>共 {list.length} 篇文章</p>
  </section>
  <section class="post-list" aria-label="标签文章列表">
    {list.map((post) => (
      <PostCard
        href={`/posts/${post.slug}`}
        title={post.data.title}
        description={post.data.description}
        publishDate={post.data.publishDate}
        tags={post.data.tags}
      />
    ))}
  </section>
</BaseLayout>
