---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Pagination from "../components/Pagination.astro";
import { getPublishedPosts, paginate } from "../lib/posts";

const PAGE_SIZE = 6;
const posts = await getPublishedPosts();
const result = paginate(posts, 1, PAGE_SIZE);
---

<BaseLayout title="首页 | Sakurairo Astro" description="Sakurairo Astro 博客首页">
  <section class="hero">
    <h1>文章列表</h1>
    <p>这是从 Sakurairo WordPress 主题迁移到 Astro 的第一版主题骨架。</p>
  </section>

  <section class="post-list" aria-label="文章列表">
    {result.items.map((post) => (
      <PostCard
        href={`/posts/${post.slug}`}
        title={post.data.title}
        description={post.data.description}
        publishDate={post.data.publishDate}
        tags={post.data.tags}
      />
    ))}
  </section>
  <Pagination current={1} total={result.total} basePath="/" />
</BaseLayout>
