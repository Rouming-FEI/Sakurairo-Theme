---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, groupPostsByYear } from "../../lib/posts";

const posts = await getPublishedPosts();
const yearMap = groupPostsByYear(posts);
const years = [...yearMap.entries()].sort((a, b) => Number(b[0]) - Number(a[0]));
---

<BaseLayout title="归档 | Sakurairo Astro" description="按年份归档文章">
  <section class="article-shell">
    <h1>文章归档</h1>
    {years.map(([year, yearPosts]) => (
      <section class="archive-year">
        <h2>{year}</h2>
        <ul class="archive-list">
          {yearPosts.map((post) => (
            <li>
              <a href={`/posts/${post.slug}`}>{post.data.title}</a>
              <time>{post.data.publishDate.toLocaleDateString("zh-CN")}</time>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>
