---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import { getPublishedPosts, paginate } from "../../lib/posts";

export async function getStaticPaths() {
  const pageSize = 6;
  const posts = await getPublishedPosts();
  const total = Math.max(1, Math.ceil(posts.length / pageSize));

  return Array.from({ length: total - 1 }, (_, index) => ({
    params: { page: String(index + 2) }
  }));
}

const page = Number(Astro.params.page || "1");
const posts = await getPublishedPosts();
const result = paginate(posts, page, 6);
---

<BaseLayout title={`第 ${result.current} 页 | Sakurairo Astro`} description="分页文章列表">
  <section class="hero">
    <h1>文章列表 - 第 {result.current} 页</h1>
  </section>
  <section class="post-list" aria-label="文章列表分页">
    {result.items.map((post) => (
      <PostCard
        href={`/posts/${post.slug}`}
        title={post.data.title}
        description={post.data.description}
        publishDate={post.data.publishDate}
        tags={post.data.tags}
      />
    ))}
  </section>
  <Pagination current={result.current} total={result.total} basePath="/" />
</BaseLayout>
