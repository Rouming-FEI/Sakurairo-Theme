---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, getCategoryMap, slugifyTerm } from "../../lib/posts";

const posts = await getPublishedPosts();
const categories = [...getCategoryMap(posts).entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="分类 | Sakurairo Astro" description="文章分类聚合页">
  <section class="article-shell">
    <h1>分类</h1>
    <ul class="tag-cloud">
      {categories.map(([category, list]) => (
        <li>
          <a href={`/categories/${slugifyTerm(category)}`}>{category} ({list.length})</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
