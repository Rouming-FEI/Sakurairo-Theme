---
import { siteConfig } from "../config/site";

const comments = siteConfig.comments;
---

<section class="comment-box" aria-label="评论区">
  <h2>评论</h2>
  {
    comments.enabled ? (
      <script
        src="https://giscus.app/client.js"
        data-repo={comments.repo}
        data-repo-id={comments.repoId}
        data-category={comments.category}
        data-category-id={comments.categoryId}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="light"
        data-lang="zh-CN"
        crossorigin="anonymous"
        async
      />
    ) : (
      <p>请在 site 配置中填写 Giscus 参数后启用评论。</p>
    )
  }
</section>
